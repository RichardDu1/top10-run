---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const toolsEntries = await getCollection('tools');
  return toolsEntries.map(entry => ({
    params: { lang: entry.data.locale, slug: entry.id.split('/').pop() },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title}>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <div class="prose prose-xl prose-invert prose-purple max-w-none 
                prose-h1:text-5xl prose-h1:font-black prose-h1:uppercase prose-h1:tracking-tighter prose-h1:mb-12
                prose-h2:text-4xl prose-h2:font-bold prose-h2:mt-16 prose-h2:mb-6 prose-h2:border-b-4 prose-h2:border-purple-500 prose-h2:pb-2
                prose-a:text-purple-400 prose-a:font-bold prose-a:no-underline hover:prose-a:underline
                prose-strong:text-purple-400">
      <Content />
    </div>
  </main>
</BaseLayout>
