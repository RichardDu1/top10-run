---
// Root path — returns 200 with canonical pointing to /en/ (CRITICAL: no redirect)
// Per BUILD_GUIDE.md Section V
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Card from '../../components/Card.astro';

// Fetch tools for English locale
const allTools = await getCollection('tools', ({ data }) => {
  return data.locale === 'en';
});

// Sort by pubDate descending
const sortedTools = allTools.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = 'Fast Top 10 Lists | top10.run';
const pageDescription = 'No fluff. No 5,000-word intros. Just the top 10 best options for whatever you are looking for.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://top10.run/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <!-- Brutalist Header -->
  <header class="bg-primary text-black border-b-[8px] border-black pt-20 pb-12 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-end gap-8">
      <div>
        <h1 class="text-6xl md:text-9xl font-black tracking-tighter leading-[0.8] mb-4">
          TOP 10.<br/>RUN.
        </h1>
        <p class="text-xl md:text-3xl font-bold uppercase tracking-tight max-w-xl">
          Zero fluff. Fast answers. The definitive list for everything.
        </p>
      </div>
      <div class="bg-black text-primary p-4 font-bold uppercase text-2xl rotate-3 shadow-[8px_8px_0_0_rgba(0,0,0,0.5)]">
        NO BS ALLOWED
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-12 border-x-[8px] border-border min-h-screen">
    
    <div class="flex items-center justify-between border-b-4 border-border pb-4 mb-12">
      <h2 class="text-3xl font-bold">LATEST RANKINGS</h2>
      <button class="bg-primary text-black font-bold uppercase px-6 py-2 hover:bg-white transition-colors">View All</button>
    </div>

    {sortedTools.map((tool, index) => (
      <a href={`/en/tools/${tool.id.split('/').pop()}`} class="block flex flex-col md:flex-row gap-8 items-center border-b-2 border-border pb-12 mb-12 group cursor-pointer">
        <div class="brutalist-number md:w-1/4 text-center group-hover:text-primary transition-colors">
          {(index + 1).toString().padStart(2, '0')}
        </div>
        <div class="md:w-3/4">
          <div class="flex gap-2 mb-4">
            <span class="bg-primary text-black text-xs font-bold uppercase px-3 py-1">{tool.data.category || 'Tech'}</span>
            <span class="border border-border text-muted text-xs font-bold uppercase px-3 py-1">
              {tool.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </span>
          </div>
          <h3 class="text-4xl md:text-5xl font-bold mb-4 group-hover:underline decoration-primary decoration-[4px] underline-offset-4 leading-tight">
            {tool.data.title}
          </h3>
          <p class="text-xl text-muted line-clamp-2">{tool.data.description}</p>
        </div>
      </a>
    ))}

  </main>

</BaseLayout>
