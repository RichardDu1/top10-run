---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = 'Top 10 Run — B2B Software & SaaS Rankings';
const pageDescription = 'The ultimate top 10 rankings for B2B SaaS, CRM, ERP, and Enterprise Software.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://top10.run/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="Discover the Top 10 SaaS Tools for Your Business" subtitle="Data-driven rankings of the best B2B software solutions." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="CRM Systems" description="Top 10 CRM for Sales" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="ERP Software" description="Top 10 Enterprise ERPs" href="/en/categories/c2/" tag="New" />
      <Card title="Marketing Automation" description="Top 10 Marketing Tools" href="/en/categories/c3/" />
      <Card title="HR Tech" description="Top 10 HR platforms" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="Top 10 Salesforce Alternatives" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="HubSpot Review 2026" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="Top 10 Payroll Softwares" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>
